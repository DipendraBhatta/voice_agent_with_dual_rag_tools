piper
piper/
piper_libs/
piper_linux_x86_64.tar.gz

# =========================
# Data Whitelisting (SBC & SPD)
# =========================
# Block general ingestion paths
indexing_for_sbc/ingestion_results/*
indexing_for_spd/ingestion_results/*
indexing_for_spd/query_retrieval/
indexing_for_spd/ingestion/
indexing_for_spd/COST_PERFORMANCE.txt

# Un-ignore ONLY specific final indexing targets
!indexing_for_sbc/ingestion_results/local_level_health_ppo_health_plan_sbc/
!indexing_for_sbc/ingestion_results/local_level_health_ppo_health_plan_sbc/indexing_results/
!indexing_for_sbc/ingestion_results/local_level_health_ppo_health_plan_sbc/indexing_results/Final_Indexing.json

!indexing_for_spd/ingestion_results/local_level_health_ppo_health_plan_spd (1)/
!indexing_for_spd/ingestion_results/local_level_health_ppo_health_plan_spd (1)/indexing_results/
!indexing_for_spd/ingestion_results/local_level_health_ppo_health_plan_spd (1)/indexing_results/master_indexing.json